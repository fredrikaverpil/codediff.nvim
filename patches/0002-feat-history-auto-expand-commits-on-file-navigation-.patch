-      current_index = i
-      break
-    end
+  local current_commit = commits[commit_idx]
+  local files = collect_commit_files(history.tree, current_commit)
+
+  -- Not at boundary: go to next file in same commit
+  if file_idx < #files then
+    local next_file = files[file_idx + 1]
